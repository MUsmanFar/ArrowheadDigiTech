# Database
DATABASE_URL="postgresql://user:password@localhost:5432/arrowhead_digitech?schema=public"
# Set to 'true' to use the local file-based JSON database (mock-db.json) for development without PostgreSQL
DB_MOCK="true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Email (Nodemailer or SendGrid)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="info@arrowheaddigitech.com"

# SendGrid (optional)
SENDGRID_API_KEY="your-sendgrid-api-key"

# Admin Credentials (default admin)
ADMIN_EMAIL="admin@arrowheaddigitech.com"
ADMIN_PASSWORD="admin123"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

    "autoprefixer": "^10.4.20",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.7",
    "lucide-react": "^0.451.0",
    "next": "^16.2.9",
    "nodemailer": "^9.0.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.53.1",
    "sharp": "^0.33.5",

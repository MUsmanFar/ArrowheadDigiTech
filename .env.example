# Database
# App runtime: use Neon pooled URL (append ?sslmode=require&pgbouncer=true)
DATABASE_URL="postgresql://user:password@localhost:5432/arrowhead_digitech?schema=public"
# Migrations/introspection: use direct (non-pooled) URL. For local dev, same as DATABASE_URL is fine.
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/arrowhead_digitech?schema=public"
# Development only. Production startup rejects DB_MOCK=true.
DB_MOCK="false"

# Required in production. Generate a unique value with at least 32 characters.
JWT_SECRET="replace-with-a-long-random-secret"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Email (Nodemailer or SendGrid)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="info@arrowheaddigitech.com"
EMAIL_TO="info@arrowheaddigitech.com"

# SendGrid (optional)
SENDGRID_API_KEY="your-sendgrid-api-key"

# Admin Credentials (default admin)
ADMIN_EMAIL="admin@arrowheaddigitech.com"
ADMIN_PASSWORD="admin123"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 (required in production for media uploads)
# See docs/CLOUDFLARE-R2-SETUP.md for bucket creation and deployment.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public CDN URL for the bucket (custom domain or r2.dev), no trailing slash
R2_PUBLIC_URL="https://media.example.com"
# Development only: set to "false" to force local public/uploads even when R2 is configured
USE_R2_UPLOADS="true"
